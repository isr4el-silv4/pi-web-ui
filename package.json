{
  "name": "pi-web-ui",
  "version": "1.0.0",
  "private": false,
  "description": "Chrome side-panel UI and local bridge extension for Pi.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "pi-coding-agent",
    "chrome",
    "chromium",
    "ai",
    "harness",
    "browser-tools"
  ],
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@sinclair/typebox": "^0.34.49",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "dompurify": "^3.4.9",
    "marked": "^18.0.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "bin": {
    "pi-web-ui": "dist/pi-extension/cli.js"
  }
}
